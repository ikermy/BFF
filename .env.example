# BFF — Barcode BFF Service
# Скопируйте этот файл в .env и заполните значения

# ── BFF ────────────────────────────────────────────────────────────────────
BFF_PORT=8080
INTERNAL_SERVICE_JWT=dev-internal-token
ADMIN_JWT=dev-admin-token
UNIT_PRICE=0.50

# ── Downstream сервисы ─────────────────────────────────────────────────────
# Используются в prod-like режиме (`make prod-up`).
BARCODEGEN_URL=http://barcodegen:8080
BILLING_URL=http://billing:3000
AI_URL=http://ai-service:8080
HISTORY_URL=http://history:3000

# ── Legacy сервисы ─────────────────────────────────────────────────────────
AUTH_URL=http://auth-service:3000
NOTIFICATIONS_URL=http://notifications:3000
TRANS_HISTORY_URL=http://trans-history:3000

# ── Kafka ──────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092

# ── Redis (для идемпотентности в production) ────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Таймауты (в миллисекундах) ─────────────────────────────────────────────
BARCODEGEN_TIMEOUT=30000
BILLING_TIMEOUT=5000
AI_TIMEOUT=60000

# ── Идемпотентность TTL (в секундах, 86400 = 24 часа) ─────────────────────
IDEMPOTENCY_TTL=86400

# ── Feature flags (п.15 ТЗ) ────────────────────────────────────────────────
ENABLE_PARTIAL_SUCCESS=true
ENABLE_IDEMPOTENCY=true
ENABLE_LEGACY_AUTH=true
ENABLE_NOTIFICATIONS=true

# ── Rollback / maintenance (п.19 ТЗ) ───────────────────────────────────────
MAINTENANCE_MODE=false

# ── Observability ───────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ANONYMOUS_ENABLED=false

